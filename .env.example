# =============================================================================
# Telegram Inspection Bot — Environment Variables
# Copy this file to .env and fill in the values before running the bot.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Frappe / ERPNext connection (REQUIRED)
# -----------------------------------------------------------------------------

# Base URL of the Frappe instance, e.g. https://erp.example.com
FRAPPE_URL=https://erp.example.com

# Frappe API Key (from User → API Access)
FRAPPE_API_KEY=your_frappe_api_key_here

# Frappe API Secret (from User → API Access)
FRAPPE_API_SECRET=your_frappe_api_secret_here

# -----------------------------------------------------------------------------
# Telegram Bot (REQUIRED)
# -----------------------------------------------------------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# -----------------------------------------------------------------------------
# Redis (REQUIRED)
# -----------------------------------------------------------------------------

# Redis connection URL, e.g. redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Session TTL in seconds (default: 86400 = 24 hours)
REDIS_TTL=86400

# -----------------------------------------------------------------------------
# Webhook server (REQUIRED)
# -----------------------------------------------------------------------------

# Host to bind the aiohttp webhook server (default: 0.0.0.0)
WEBHOOK_HOST=0.0.0.0

# Port to bind the aiohttp webhook server (default: 8443)
WEBHOOK_PORT=8443

# Shared secret for the /webhook/inspection-request endpoint.
# Frappe must send this value in the X-Inspection-Webhook-Secret header.
# If not set, the bot will log a WARNING and accept all requests (dev mode only).
WEBHOOK_SHARED_SECRET=change_me_to_a_strong_random_secret

# -----------------------------------------------------------------------------
# Optional tuning
# -----------------------------------------------------------------------------

# TTL (seconds) for the in-memory auth cache per telegram_id (default: 60)
AUTH_CACHE_TTL_SECONDS=60

# Timeout (seconds) for outbound HTTP requests to Frappe (default: 30)
FRAPPE_REQUEST_TIMEOUT_SECONDS=30

# Maximum photo size in bytes before compression is applied (default: 5242880 = 5 MB)
PHOTO_MAX_BYTES=5242880

# Target longest edge (pixels) when downscaling oversized photos (default: 1920)
PHOTO_COMPRESS_TARGET_LONGEST_EDGE=1920

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Admin contact shown in /bantuan command (optional, leave blank to omit)
ADMIN_CONTACT=
